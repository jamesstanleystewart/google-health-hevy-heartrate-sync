# ============================================================================
# Hevy (public v1 API — UUID key from app.hevyapp.com > Settings)
# ============================================================================
HEVY_API_KEY=

# ============================================================================
# Hevy (private v2 mobile API — extracted from the `auth2.0-token` cookie
# at https://app.hevyapp.com — DevTools > Application > Cookies).
# URL-decode the cookie value, parse the JSON, copy the three fields below.
#
# These are BOOTSTRAP only — on first run, the function writes them to GCS,
# and from then on GCS is the authoritative source. Refresh-token rotation
# happens automatically and is persisted there. To force re-bootstrap (e.g.
# after a long downtime), delete the GCS object and redeploy.
# ============================================================================
HEVY_ACCESS_TOKEN=
HEVY_REFRESH_TOKEN=
HEVY_EXPIRES_AT=

# Bucket + object that store the rotated token triple between invocations.
# Create with: gcloud storage buckets create gs://YOUR_BUCKET --location=us-central1
HEVY_TOKEN_BUCKET=
HEVY_TOKEN_OBJECT=hevy-tokens.json

# ============================================================================
# Google Health API v4
# Get CLIENT_ID + CLIENT_SECRET from GCP Console > APIs & Services > Credentials
# Get REFRESH_TOKEN from https://developers.google.com/oauthplayground:
#   1. Gear icon > "Use your own OAuth credentials" > paste id/secret
#   2. Step 1: scroll to bottom, manually paste scope:
#      https://www.googleapis.com/auth/googlehealth.health_metrics_and_measurements.readonly
#   3. Authorize APIs (must sign in as the test account)
#   4. Exchange authorization code for tokens
#   5. Copy the refresh_token
# ============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ============================================================================
# Dry-run only — a workout id to test reads against (no mutation occurs)
# ============================================================================
TEST_WORKOUT_ID=

# ============================================================================
# Safety toggle for the deployed function: when true, the clone is POSTed but
# the original is NOT deleted. Recommend setting this to true for first-pass
# verification — you'll end up with a duplicate workout you can eyeball.
# ============================================================================
SKIP_DELETE=true

# ============================================================================
# Shared secret Hevy sends as the `Authorization` header. Must match exactly.
# Generated value lives in scripts/webhook-auth.txt (gitignored).
# Paste the same value into Hevy's webhook config + here.
# Leave empty in local dev to disable the check.
# ============================================================================
WEBHOOK_AUTH_HEADER=
